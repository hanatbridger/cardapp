# Expo public env vars — embedded in the client bundle at build time.
# Copy this file to `.env` and fill in real values for local dev.
# For TestFlight / prod, set these in EAS secrets and in the Vercel project.

# Sentry crash + performance telemetry.
# Get from: https://sentry.io/settings/<org>/projects/cardpulse/keys/
EXPO_PUBLIC_SENTRY_DSN=

# RevenueCat public SDK key (iOS).
# Get from: https://app.revenuecat.com/projects/<id>/apps
EXPO_PUBLIC_REVENUECAT_API_KEY=
